<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="edu.jxust.agritrace.mapper.ProductBatchMapper">

    <select id="selectAll" resultType="edu.jxust.agritrace.entity.ProductBatch">
        select * from product_batch
    </select>

    <select id="selectByBatchCode" resultType="edu.jxust.agritrace.entity.ProductBatch">
        SELECT *
        FROM product_batch
        WHERE batch_code = #{batchCode}
        LIMIT 1
    </select>

</mapper>
